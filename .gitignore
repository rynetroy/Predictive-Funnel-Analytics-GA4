# Raw data downloaded from Kaggle — not committed to git
data/*.csv
data/*.parquet
data/*.xlsx

# Processed data regenerated by notebook
data/processed/*
!data/processed/.gitkeep

# Model artifacts regenerated by notebook
models/*.pkl
models/*.joblib

# Keep lightweight model metadata if needed
!models/customer_spend_lookup.csv
!models/feature_names.csv
!models/.gitkeep

# Notebooks — ignore checkpoints
notebooks/.ipynb_checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/

# Environment
.venv/
venv/
env/
.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
