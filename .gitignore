# Keep folder structure, ignore actual processed data files
data/processed/*
!data/processed/.gitkeep

# Raw data (download from Kaggle — not committed to git)
data/raw/*
!data/raw/.gitkeep

# Model artifacts (regenerated by notebook)
models/*.pkl
models/*.joblib
!models/.gitkeep

# Notebooks — keep folder, ignore checkpoints
notebooks/.ipynb_checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/

# Environment
.venv/
venv/
env/
.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
