# ============================================================
# Data
# ============================================================

# Raw data downloaded from Kaggle — not committed to git
data/*.csv
data/*.parquet
data/*.xlsx

# Processed data regenerated by notebook
data/processed/*
!data/processed/.gitkeep

# Allow Streamlit deployment demo sample
!data/processed/scored_sample_sessions.csv


# ============================================================
# Model artifacts
# ============================================================

# Ignore regenerated model artifacts by default
models/*.pkl
models/*.joblib

# Allow deployment artifacts needed by Streamlit app
!models/pfa_ga4_propensity_model.joblib
!models/feature_names.joblib

# Keep lightweight model metadata
!models/customer_spend_lookup.csv
!models/feature_names.csv
!models/.gitkeep


# ============================================================
# Reports and visualizations
# ============================================================

# Keep committed visualizations and reports unless manually removed
# Add exclusions here later if files become too large


# ============================================================
# Notebooks
# ============================================================

# Ignore notebook checkpoints
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/


# ============================================================
# Python
# ============================================================

__pycache__/
*.pyc
*.pyo
*.pyd


# ============================================================
# Environment
# ============================================================

.venv/
venv/
env/
.env


# ============================================================
# OS files
# ============================================================

.DS_Store
Thumbs.db


# ============================================================
# IDE
# ============================================================

.vscode/
.idea/
